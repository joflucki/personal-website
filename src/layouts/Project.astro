---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { toBCP47 } from "../i18n/utils";
import type { MarkdownHeading } from "astro";
import Tag from "../components/Tag.astro";
import linkIcon from "../assets/icons/link.svg";

type Props = CollectionEntry<"projects">["data"] & {
	headings: MarkdownHeading[];
};

const { _, slug } = Astro.params;

const { title, description, locale, heroImage, tags, links, headings } =
	Astro.props;
---

<html lang={toBCP47(locale)}>
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				flex-direction: column;
				display: flex;
				margin: auto;
				width: 70%;
				gap: 1em;
			}
			.table-of-contents {
				flex: 1;
				height: min-content;
				display: flex;
				flex-direction: column;
				align-items: start;
				text-align: start;
				border-right: 1px solid var(--accent);
				padding-right: 1em;
				position: sticky;
				top: 3.8em;
				min-width: 20%;
				line-height: 1.2;
				gap: 0.4em;
			}
			.table-of-contents a {
				color: var(--white);
				text-decoration-color: transparent;
				transition: text-decoration-color 0.15s linear;
			}
			.table-of-contents hr {
				margin: 0;
			}
			.table-of-contents a:hover {
				text-decoration-color: var(--white);
			}
			.content {
				display: flex;
				gap: 1em;
			}
			.prose {
				flex: 4;
				min-width: 0; /* IMPORTANT */
			}
			.prose img {
				display: block;
				width: 100%;
				height: auto;
			}
			.hero-image {
				aspect-ratio: 32 / 9;
				width: 100%;
				object-fit: cover;
				object-position: center;
				border-radius: 8px;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				translate: -3px 0;
			}
			hr {
				width: 100%;
				border: 1px solid var(--gray-dark);
			}
			.project-link {
				display: flex;
				gap: 6px;
				align-items: center;
				color: var(--white);
			}
			.project-link img {
				height: 1em;
				width: auto;
				translate: 0 3px;
			}
			@media (max-width: 720px) {
				.table-of-contents {
					display: none;
				}
				main {
					translate: none;
					width: 90%;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="hero-image-container">
				<img
					class="hero-image"
					src={heroImage?.src ?? ""}
					alt="A decorative image for the project"
				/>
			</div>
			<h1 class="title">{title}</h1>
			<div class="project-links-container">
				{
					links?.map((link) => (
						<a class="project-link" href={`https://${link}`}>
							<Image src={linkIcon} alt="An icon of a link" />{" "}
							{link}
						</a>
					))
				}
			</div>
			<div class="tags">
				{tags.map((tag) => <Tag {tag} />)}
			</div>
			<hr />
			<div class="content">
				<div class="table-of-contents">
					{
						headings
							.filter((heading) => heading.depth < 3)
							.flatMap((heading, i, _) => (
								<>
									{i > 0 && <hr />}
									<a href={`#${heading.slug}`}>
										{heading.text}
									</a>
								</>
							))
					}
				</div>
				<div class="prose">
					<slot />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
